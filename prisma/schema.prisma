// Prisma schema for Drug Shortage Dashboard
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

// ScrapeStatus kept as String (enum migration requires manual SQL cast with existing data)
// Values: 'success' | 'error'

enum OffMarketCategory {
  AUSSER_HANDEL
  VERTRIEBSEINSTELLUNG
  ERLOSCHEN
}

// ── Models ────────────────────────────────────────────────────────────────────

model Shortage {
  id                    Int      @id @default(autoincrement())
  gtin                  String   @unique
  pharmacode            String
  bezeichnung           String
  // slug: URL-friendly version of bezeichnung — avoids full table scan in getShortageBySlug
  slug                  String?  @unique
  firma                 String
  atcCode               String
  gengrp                String
  statusCode            Int
  // statusText is derivable from statusCode — nullable for deprecation, will be dropped later
  statusText            String?
  datumLieferfahigkeit  String
  datumLetzteMutation   String
  tageSeitMeldung       Int
  detailUrl             String
  alternativenUrl       String?
  // Detail page fields
  ersteMeldung          String?
  ersteMeldungDurch     String?
  ersteInfoDurchFirma   String?
  artDerInfoDurchFirma  String?
  voraussichtlicheDauer String?
  bemerkungen           String?
  // Tracking
  firstSeenAt           DateTime
  lastSeenAt            DateTime
  isActive              Boolean  @default(true)
  occurrenceCount       Int      @default(1)

  // Hot path: main table query (WHERE isActive=true AND statusCode 1-5 ORDER BY tageSeitMeldung DESC)
  @@index([isActive, statusCode, tageSeitMeldung(sort: Desc)], map: "idx_shortages_active_status_days")
  // Filter queries
  @@index([firma],                 map: "idx_shortages_firma")
  @@index([atcCode],               map: "idx_shortages_atc")
  // Historical queries (inactive entries by firma/gengrp)
  @@index([isActive, firma],       map: "idx_shortages_inactive_firma")
  @@index([isActive, gengrp],      map: "idx_shortages_inactive_gengrp")
  @@map("shortages")
}

model OverviewStats {
  id                            Int      @id @default(autoincrement())
  scrapedAt                     DateTime
  totalPackungen                Int
  totalProdukte                 Int
  betroffeneAtcGruppen          Int
  pflichtlager                  Int
  bwl                           Int
  bwlWho                        Int
  who                           Int
  kassenpflichtigSL             Int
  kassenpflichtigSLTotal        Int
  prozentSLNichtLieferbar       Float
  dauerUnter2Wochen             Int
  dauer2bis6Wochen              Int
  dauerUeber6WochenBis6Monate   Int
  dauerUeber6MonateBis1Jahr     Int
  dauerUeber1Bis2Jahre          Int
  dauerUeber2Jahre              Int
  swissmedicListeA              Int
  swissmedicListeATotal         Int
  swissmedicListeB              Int
  swissmedicListeBTotal         Int
  swissmedicListeC              Int
  swissmedicListeCTotal         Int
  swissmedicUebrige             Int
  swissmedicUebrigeTotal        Int
  firmenRanking                 Json
  atcGruppen                    Json

  @@index([scrapedAt(sort: Desc)], map: "idx_overview_stats_scrapedat")
  @@map("overview_stats")
}

model AlternativesCache {
  gtin      String   @id
  data      Json
  fetchedAt DateTime @updatedAt

  @@map("alternatives_cache")
}

model ScrapeRun {
  id             Int          @id @default(autoincrement())
  scrapedAt      DateTime
  totalCount     Int
  newEntries     Int
  removedEntries Int
  status         String   // 'success' | 'error'
  errorMessage   String?

  @@index([status, scrapedAt(sort: Desc)], map: "idx_scrape_runs_status_date")
  @@map("scrape_runs")
}

// ODDB product enrichment — from download.hin.ch/download/oddb2xml (daily)
// Contains: GTIN, Swissmedic-Nr, Wirkstoff, Zusammensetzung, ATC
// Prices (ppub/pexf) are synced separately from oddb_article.xml (weekly)
model OddbProduct {
  id              Int      @id @default(autoincrement())
  gtin            String   @unique
  prodno          String   // Swissmedic product number e.g. "0060201"
  bezeichnungDe   String
  atcCode         String
  substanz        String?
  zusammensetzung String?
  ppub            Float?   // Publikumspreis in CHF (public price incl. VAT)
  pexf            Float?   // Fabrikabgabepreis in CHF (ex-factory price)
  authStatus      String?  // Swissmedic authorization status: 'A'=active, 'E'=erloschen, 'S'=sistiert etc.
  fetchedAt       DateTime @updatedAt

  @@map("oddb_products")
}

// BWL federal supply shortage list (Bundesamt für wirtschaftliche Landesversorgung)
// Source: https://www.bwl.admin.ch/de/meldestelle-heilmittel
model BwlShortage {
  id                    Int      @id @default(autoincrement())
  gtin                  String   @unique
  atcCode               String
  bezeichnung           String
  eintrittsdatum        String?
  voraussichtlicheDauer String?
  bemerkungen           String?
  datumPublikation      String?
  letzteAktualisierung  String?
  fetchedAt             DateTime @updatedAt

  @@map("bwl_shortages")
}

// Per-drug shortage episode log — one row per distinct shortage period
// startedAt = first seen in scrape, endedAt = null (still active) or date removed from scrape
// durationDays is denormalised and set when the episode is closed (fast aggregation queries)
model ShortageEpisode {
  id           Int       @id @default(autoincrement())
  gtin         String
  startedAt    DateTime
  endedAt      DateTime?
  durationDays Int?      // null while active; set on close

  // Per-drug history (most recent first)
  @@index([gtin, startedAt(sort: Desc)], map: "idx_episodes_gtin_start")
  // "All currently active" / "All closed" queries
  @@index([endedAt],                     map: "idx_episodes_ended_at")
  // Global timeline
  @@index([startedAt(sort: Desc)],       map: "idx_episodes_timeline")
  @@map("shortage_episodes")
}

// Watchlist subscriptions: users subscribe to ATC codes and receive email alerts on shortage changes
model WatchlistSubscription {
  id          Int       @id @default(autoincrement())
  email       String
  atcCode     String
  token       String    @unique @default(cuid())
  confirmed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  lastAlertAt DateTime?

  @@unique([email, atcCode], map: "uq_watchlist_email_atc")
  @@index([atcCode, confirmed], map: "idx_watchlist_atc_confirmed")
  @@index([confirmed],          map: "idx_watchlist_confirmed")
  @@map("watchlist_subscriptions")
}

// Off-market drugs: permanently withdrawn (ausserHandel), sales discontinued (Vertriebseinstellung), or authorization expired (Erlöschen)
// Source: drugshortage.ch/ausserHandel.aspx + drugshortage.ch/Vertriebseinstellung.aspx + oddb_products (authStatus E/S)
// Note: "datum" meaning differs by category:
//   AUSSER_HANDEL        → date the drug went off market
//   VERTRIEBSEINSTELLUNG → date of last mutation / sales cessation
//   ERLOSCHEN            → null (ODDB does not provide expiry date)
model OffMarketDrug {
  id          Int               @id @default(autoincrement())
  gtin        String
  bezeichnung String
  firma       String
  atcCode     String?
  datum       String?
  category    OffMarketCategory
  fetchedAt   DateTime          @updatedAt

  // A GTIN can exist in both categories (off-market AND sales-discontinued)
  @@unique([gtin, category], map: "uq_offmarket_gtin_category")
  @@index([category, firma],   map: "idx_offmarket_category_firma")
  @@index([category, atcCode], map: "idx_offmarket_category_atc")
  @@map("off_market_drugs")
}

// Stripe customer — one row per paying email
model StripeCustomer {
  id        String   @id @default(cuid())
  email     String   @unique
  stripeId  String   @unique
  createdAt DateTime @default(now())
  apiKeys   ApiKey[]

  @@map("stripe_customers")
}

// API keys — free (IP-based, no row), research, professional, institutional, data_license
model ApiKey {
  id             String          @id @default(cuid())
  customerId     String?
  customer       StripeCustomer? @relation(fields: [customerId], references: [id])
  keyHash        String          @unique
  keyEncrypted   String?         // AES-256-GCM encrypted plaintext key for dashboard display
  tier           String          @default("free")
  dailyLimit     Int             @default(100)
  dailyCount     Int             @default(0)
  lastReset      DateTime        @default(now())
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())

  @@index([keyHash], map: "idx_api_keys_hash")
  @@map("api_keys")
}

// USB Basel (Universitätsspital Basel, Spitalpharmazie) weekly PDF report
// Source: https://www.spitalpharmazie-basel.ch/Lieferengpassbericht.pdf
// No GTIN available — SAP-Nr. is internal USB identifier, not globally unique
// Key value: infoBezueger field contains substitute/alternative drug recommendations
model UsbShortage {
  id           Int      @id @default(autoincrement())
  beginn       String?  // original date string from PDF (e.g. "01.04.25")
  sapNr        String   // SAP number (USB-internal identifier)
  praeparat    String
  wirkstoffe   String
  hersteller   String
  infoBezueger String   @db.Text // often multi-line, contains substitute recommendations
  fetchedAt    DateTime @updatedAt

  @@unique([sapNr], map: "uq_usb_sapnr")
  @@index([hersteller], map: "idx_usb_hersteller")
  @@map("usb_shortages")
}
